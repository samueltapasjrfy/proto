# =========================================================
# Credenciais eproc-MG (modo single-client direto do .env)
# =========================================================
# Usadas quando você roda:  python main.py login
EPROC_MG_USUARIO=
EPROC_MG_SENHA=
# Por padrão é base32 (A-Z, 2-7) — formato que o eproc mostra na tela de cadastro
# do 2FA e que o Google Authenticator usa. Para outros formatos, prefixe:
#   hex:4a30b91c...         (bytes em hex)
#   ascii:meu_secret         (ASCII literal)
#   otpauth://totp/...       (URI completa do QR code)
EPROC_MG_TOTP_SECRET=

# eproc-RS — mesmas regras de formato do TOTP
EPROC_RS_USUARIO=
EPROC_RS_SENHA=
EPROC_RS_TOTP_SECRET=

# eproc-SP — idem
EPROC_SP_USUARIO=
EPROC_SP_SENHA=
EPROC_SP_TOTP_SECRET=

# =========================================================
# Multi-client opcional (clientes.json com senhas cifradas)
# =========================================================
# Só preencha se for usar `python main.py login --cliente <id>`.
# Gere com:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
RPA_MASTER_KEY=

# =========================================================
# Banco de dados (MySQL) — fonte dos protocolos aptos
# =========================================================
# Usado por `python main.py listar-aptos` e pelo serviço de orquestração.
RPA_DB_HOST=
RPA_DB_PORT=3306
RPA_DB_USER=
RPA_DB_PASSWORD=
RPA_DB_NAME=

# =========================================================
# Painel Jurify — finalização (upload do recibo + status concluído)
# =========================================================
# Credenciais do bucket S3 do Jurify (NÃO são as creds por-arquivo de
# tbarquivosprocesso — essas vêm do banco). Pegue do .env do RPAGateway.
RPA_JURIFY_AWS_ACCESS_KEY=
RPA_JURIFY_AWS_SECRET_KEY=
RPA_JURIFY_AWS_BUCKET=netview-tw
RPA_JURIFY_AWS_REGION=us-east-1
# Identificadores que aparecem no painel pra rastrear o robô.
RPA_JURIFY_USER_ID=1
RPA_JURIFY_USER_NAME=ROBO.RPAPROTOCOLO

# =========================================================
# Tuning opcional
# =========================================================
# Caminho base dos dados (default = ./data)
# RPA_DATA_DIR=./data

# Headless do Playwright (true/false). Default = false durante desenvolvimento.
# RPA_HEADLESS=false

# Timeout em segundos para detectar 2FA/painel após o submit. Default = 25.
# RPA_LOGIN_TIMEOUT=25
